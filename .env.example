# PUBLIC TEMPLATE ONLY. Copy to a protected runtime directory outside this repo.
# Never place office/Production endpoints, identifiers, or credentials here.

DCIM_ENV=dev-build
DCIM_LOG_LEVEL=INFO
DCIM_TIMEZONE=UTC

# Development profiles; values are illustrative and use synthetic data only.
COMPOSE_PROFILES=core,data,dashboard
POSTGRES_DB=dcim_dev
POSTGRES_USER=dcim_dev
POSTGRES_PASSWORD=<SET_LOCALLY>
REDIS_PASSWORD=<SET_LOCALLY>
KAFKA_CLUSTER_ID=<GENERATE_LOCALLY>
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<SET_LOCALLY>

# Runtime paths MUST resolve outside the repository.
DCIM_RUNTIME_ROOT=../dcim-runtime
DCIM_FIXTURE_ROOT=./fixtures/synthetic

# Connector controls. Keep disabled until authorization and read-only tests exist.
ENABLE_REDFISH_CONNECTOR=false
ENABLE_SNMP_CONNECTOR=false
ENABLE_PRODUCTION_CONNECTED_PLANE=false
CONNECTOR_KILL_SWITCH=true

# No live endpoints belong in this template.
REDFISH_BASE_URL=https://192.0.2.10
SNMP_TARGET=198.51.100.20
