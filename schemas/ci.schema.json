{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/dcim/ci.schema.json",
  "title": "DCIM Configuration Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ci_id",
    "source_system",
    "native_device_id",
    "ci_type",
    "aliases",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "ci_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_system": {
      "type": "string",
      "minLength": 1
    },
    "native_device_id": {
      "type": "string",
      "minLength": 1
    },
    "asset_id": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "ci_type": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "value",
          "valid_from",
          "source",
          "confidence"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "hostname",
              "fqdn",
              "ip",
              "source_native_id",
              "asset_tag",
              "other"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "valid_from": {
            "type": "string",
            "format": "date-time"
          },
          "valid_to": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
