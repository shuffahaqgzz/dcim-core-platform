{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/dcim/asset.schema.json",
  "title": "DCIM Asset",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "identity",
    "asset_type",
    "aliases",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "asset_id": {
      "type": "string",
      "format": "uuid"
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "native_uuid": {
          "type": "string",
          "format": "uuid"
        },
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "serial_number": {
          "type": "string",
          "minLength": 1
        }
      },
      "oneOf": [
        {
          "required": [
            "native_uuid"
          ]
        },
        {
          "required": [
            "manufacturer",
            "serial_number"
          ]
        }
      ]
    },
    "asset_type": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "value",
          "valid_from",
          "source",
          "confidence"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "hostname",
              "fqdn",
              "ip",
              "source_native_id",
              "asset_tag",
              "other"
            ]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "valid_from": {
            "type": "string",
            "format": "date-time"
          },
          "valid_to": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
