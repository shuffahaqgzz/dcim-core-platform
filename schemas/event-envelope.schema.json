{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.example.invalid/dcim/event-envelope.schema.json",
  "title": "DCIM Canonical Event Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "observed_at",
    "source",
    "event_type",
    "priority",
    "correlation_id",
    "payload",
    "enrichment"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "instance",
        "connector",
        "transport"
      ],
      "properties": {
        "system": {
          "type": "string",
          "minLength": 1
        },
        "instance": {
          "type": "string",
          "minLength": 1
        },
        "connector": {
          "type": "string",
          "minLength": 1
        },
        "transport": {
          "type": "string",
          "enum": [
            "fixture",
            "redfish",
            "snmpv3",
            "syslog",
            "rest",
            "stream"
          ]
        },
        "native_event_id": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
    },
    "priority": {
      "type": "string",
      "enum": [
        "P1",
        "P2",
        "P3"
      ]
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "payload": {
      "type": "object"
    },
    "enrichment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validation_status",
        "lineage"
      ],
      "properties": {
        "validation_status": {
          "type": "string",
          "enum": [
            "accepted",
            "quarantined"
          ]
        },
        "lineage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "step",
              "at"
            ],
            "properties": {
              "step": {
                "type": "string",
                "minLength": 1
              },
              "at": {
                "type": "string",
                "format": "date-time"
              },
              "result": {
                "type": "string"
              }
            }
          }
        },
        "asset_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "ci_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "quality_flags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
